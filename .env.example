# Environment Configuration Template
# Copy this file to .env.local and fill in the values

# ==================== API Configuration ====================
# Backend API URL - REQUIRED in production
# Development default: http://localhost:8080
# Production: Railway backend deployment
NEXT_PUBLIC_API_URL=https://developer-potomaac.up.railway.app

# ==================== Node Environment ====================
# Automatically set by Next.js, but can be overridden
# Values: development | production | test
NODE_ENV=development

# ==================== Optional: External Services ====================
# Add any external service API keys here
# NEXT_PUBLIC_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=
